{
    "manifest_version": 3,
    "name": "Placement Tracker",
    "version": "1.0",
    "description": "Capture job listings and send to Placement Tracker",
    "permissions": [
      "activeTab",
      "storage"
    ],
    "action": {
      "default_popup": "popup.html",
      "default_title": "Placement Tracker"
    },
    "content_scripts": [
      {
        "matches": ["<all_urls>"],
        "js": ["content.js"]
      }
    ]
  }